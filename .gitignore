# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyd

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Data and large datasets (Ignore files inside but keep directory structure)
data/raw/*
data/processed/*
data/scored/*
home-credit-default-risk/
*.zip
*.gz
*.tar
*.tgz
data.txt

# Exempt .gitkeep files and required backend data so they are committed to GitHub
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/scored/.gitkeep
!data/scored/scored_customers.parquet
!data/scored/shap_top10.parquet
!data/scored/shap_global.parquet

# Models and serialization outputs (Keep folder structure, ignore contents)
models/*
!models/.gitkeep

# Metrics and logs
outputs/*
!outputs/.gitkeep
!outputs/metrics.json
catboost_info/
*.log

# IDEs, system and workspace settings
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Documentation and AI Prompts
*.md
!README.md
docs/
claude_prompt*
IDBI_methodology*
IDBI_project_doc*
creditpulse_cursor_master_prompt*
*.pdf
*.pptx
*.ipynb
